</head>

<body>

<div class="profile" id="profile">

  <h1><%= member.name %></h1>
  <h3><%= member.role %></h3>

  <!-- <p><strong>Email:</strong> <%= member.email %></p> -->

  <p>
    <strong>LinkedIn:</strong>
    <a href="<%= member.linkedin %>" target="_blank">View Profile</a>
  </p>

  <p><strong>Why Joined:</strong> <%= member.reason %></p>

  <a href="/about" class="back-btn">⬅ Back to Members</a>
